<!DOCTYPE html>
<html>
<head>
  <script src="responsive.js"></script>
  <!-- OR CDN -->
  <!-- <script src="https://cdn.skypack.dev/responsive-mobile-first"></script> -->
  
  <style>
  
  /* Show/Hide */
.mobile-show { display: block; }
.mobile-hide { display: none; }
.tablet-show { display: none; }
.desktop-show { display: none; }

/* Layout */
.mobile- .container { padding: 1rem; }
.tablet- .grid { grid-template-columns: 1fr 1fr; }
.desktop- .grid { grid-template-columns: repeat(4, 1fr); }

/* Navigation */

nav {
  /* Mobile: bottom nav */
  .mobile- & { 
    position: fixed; bottom: 0; 
    display: flex; 
  }
  
  /* Tablet: side nav */
  .tablet- & { 
    position: sticky; width: 250px; 
  }
}

/* grid system */

.grid {
  display: grid;
  gap: 1rem;
}

.mobile- .grid { grid-template-columns: 1fr; }
.tablet- .grid { grid-template-columns: repeat(2, 1fr); }
.desktop- .grid { grid-template-columns: repeat(4, 1fr); }

/* TYPHOGRAFI */
h1 {
  font-size: 1.5rem;
  line-height: 1.2;
}

.mobile- h1 { font-size: 1.8rem; }
.tablet- h1 { font-size: 2.5rem; }
.desktop- h1 { font-size: 3.5rem; }

.hero-img {
  width: 100%; height: 200px; object-fit: cover;
}

/* image */

.mobile- .hero-img { height: 250px; }
.tablet- .hero-img { height: 400px; }
.desktop- .hero-img { height: 600px; }

</style>

</head>

<body>

  <div class="container">
  
  <!-- Mobile only -->
  <div class="card mobile-show tablet-hide desktop-hide">Mobile</div>
  
  <!-- Mobile + Tablet -->
  <div class="card mobile-show tablet-show desktop-hide">Mobile+Tablet</div>
  
  <!-- Desktop only -->
  <div class="card mobile-hide tablet-hide desktop-show">Desktop</div>
  
</div>

</body>
</html>





sample



<!DOCTYPE html>
<html>
<head>
  <style>
    * { box-sizing: border-box; margin: 0; }
    body { font-family: system-ui, sans-serif; line-height: 1.6; }
    
    .container { max-width: 1200px; margin: 0 auto; padding: 1rem; }
    .card { padding: 2rem; margin: 1rem 0; border-radius: 12px; background: #f8f9fa; }
    
    /* Mobile First */
    .mobile-show { display: block; }
    .mobile-hide { display: none; }
    .tablet-show, .desktop-show { display: none; }
    
    /* Breakpoint specific */
    .mobile- .container { padding: 1rem; }
    .tablet- .container { padding: 2rem; }
    .tablet- .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .desktop- .container { padding: 3rem; }
    .desktop- .grid { grid-template-columns: repeat(3, 1fr); }
  </style>
</head>
<body>
  <div class="container">
    <h1>Responsive Demo</h1>
    
    <div class="grid">
      <div class="card mobile-show tablet-hide desktop-hide">🦁 Mobile Only</div>
      <div class="card mobile-show tablet-show desktop-hide">📱 Mobile + Tablet</div>
      <div class="card mobile-hide tablet-show desktop-hide">💻 Tablet Only</div>
      <div class="card mobile-hide tablet-hide desktop-show">🖥️ Desktop Only</div>
    </div>
    
    <div id="debug"></div>
  </div>

  <script src="responsive.js"></script>
  <script>
    // Debug info
    document.addEventListener('screenSizeChange', (e) => {
      document.getElementById('debug').innerHTML = 
        `Size: <strong>${e.detail.size}</strong> | Width: ${e.detail.width}px`;
    });
  </script>
</body>
</html>